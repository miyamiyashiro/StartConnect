<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/investorHomeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_home_gradient"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="94dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/investor_header_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/imgHeaderProfile"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/foto_grupo" />

            <ImageView
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_circular_editar"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:padding="3dp"
                android:src="@drawable/editar_simbolo" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#FFFFFF"
                android:textSize="26sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\@Investidor"
                android:textColor="#E7FFFF"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        android:background="@drawable/card_roxo_shape"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/investor_search_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@android:drawable/ic_menu_search" />

            <EditText
                android:id="@+id/searchEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="use palavras-chave"
                android:inputType="text"
                android:paddingStart="10dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#D8F8F7" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/startupsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingBottom="8dp"
            android:scrollbars="none" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bottom_nav_background"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:weightSum="6">

        <FrameLayout
            android:id="@+id/navHomeContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Home"
            android:focusable="true">

            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/home_simbolo"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navContaContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Conta"
            android:focusable="true">

            <ImageView
                android:id="@+id/navContaIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/minhaconta_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navChatContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Chat"
            android:focusable="true">

            <ImageView
                android:id="@+id/navChatIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/chat_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navFavoritosContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Favoritos"
            android:focusable="true">

            <ImageView
                android:id="@+id/navFavoritosIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/favoritos_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navNotificacoesContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Notificacoes"
            android:focusable="true">

            <ImageView
                android:id="@+id/navNotificacoesIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/notificacao_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navSairContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Sair"
            android:focusable="true">

            <ImageView
                android:id="@+id/navSairIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/logoout_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

    </LinearLayout>

</LinearLayout>