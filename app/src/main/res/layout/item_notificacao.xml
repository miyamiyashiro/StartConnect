<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Bolinha de nao lida -->
        <View
            android:id="@+id/indicadorNaoLida"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bolinha_menu" />

        <!-- Foto circular -->
        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/foto_vazia"
            app:shapeAppearanceOverlay="@style/CircleImage" />

        <!-- Nome e mensagem -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtNotifNome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Startup"
                android:textColor="#1A1F2B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtNotifMensagem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Mensagem"
                android:textColor="#45A09E"
                android:textSize="13sp"
                android:textStyle="italic" />
        </LinearLayout>

        <!-- Data -->
        <TextView
            android:id="@+id/txtNotifData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="Ontem\n01:10 pm"
            android:textColor="#1A1F2B"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Linha separadora -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#B0D6D6" />

</LinearLayout>
