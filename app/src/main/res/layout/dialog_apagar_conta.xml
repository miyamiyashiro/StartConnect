<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_verde"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Botao X fechar -->
    <ImageView
        android:id="@+id/btnFecharApagarConta"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="end"
        android:contentDescription="Fechar"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="#FFFFFF" />

    <!-- Header com foto e titulo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/foto_grupo"
            app:shapeAppearanceOverlay="@style/CircleImage" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="Apagar\nconta"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="italic" />
    </LinearLayout>

    <!-- Texto de confirmacao -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="Tem certeza que deseja apagar a\nconta?"
        android:textColor="#FFFFFF"
        android:textSize="18sp" />

    <!-- Botoes Sim e Voltar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmarApagar"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="Sim"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:backgroundTint="#4B2C7F"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelarApagar"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:text="Voltar"
            android:textAllCaps="false"
            android:textColor="#294B50"
            android:textSize="16sp"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="16dp"
            app:strokeColor="#6BC2C8"
            app:strokeWidth="1dp" />
    </LinearLayout>

</LinearLayout>
