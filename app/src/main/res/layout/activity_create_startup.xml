<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_home_gradient"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/card_verde"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/foto_vazia" />

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_circular_editar"
                android:contentDescription="Editar foto"
                android:padding="5dp"
                android:src="@drawable/editar_simbolo" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nova&#10;Startup"
                android:textColor="#FFFFFF"
                android:textSize="28sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\@Empreendedor"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_roxo_shape"
            android:orientation="vertical"
            android:padding="26dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edittext_border_branco"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:minHeight="54dp"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/nome_conta" />

                <EditText
                    android:id="@+id/etNomeStartup"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="nome da startup"
                    android:importantForAutofill="no"
                    android:inputType="textCapWords"
                    android:paddingStart="12dp"
                    android:textColor="#335055"
                    android:textColorHint="#7A8D92" />

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:background="@drawable/bg_circular_editar"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="3dp"
                    android:src="@drawable/editar_simbolo" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edittext_border_branco"
                android:elevation="4dp"
                android:gravity="top"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/descricao_conta" />

                <EditText
                    android:id="@+id/etDescricaoStartup"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:gravity="top"
                    android:hint="descrição"
                    android:importantForAutofill="no"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="4"
                    android:paddingStart="12dp"
                    android:textColor="#335055"
                    android:textColorHint="#7A8D92" />

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_circular_editar"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="3dp"
                    android:src="@drawable/editar_simbolo" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edittext_border_branco"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:minHeight="54dp"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/area_conta" />

                <EditText
                    android:id="@+id/etAreaStartup"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="área"
                    android:importantForAutofill="no"
                    android:inputType="textCapWords"
                    android:paddingStart="12dp"
                    android:textColor="#335055"
                    android:textColorHint="#7A8D92" />

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:background="@drawable/bg_circular_editar"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="3dp"
                    android:src="@drawable/editar_simbolo" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edittext_border_branco"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:minHeight="54dp"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/cnpj_conta" />

                <EditText
                    android:id="@+id/etCnpjStartup"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="cnpj"
                    android:importantForAutofill="no"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:textColor="#335055"
                    android:textColorHint="#7A8D92" />

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:background="@drawable/bg_circular_editar"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="3dp"
                    android:src="@drawable/editar_simbolo" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="26dp"
                android:background="@drawable/edittext_border_branco"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:minHeight="54dp"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/tags_conta" />

                <EditText
                    android:id="@+id/etTagsStartup"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="tags"
                    android:importantForAutofill="no"
                    android:inputType="textCapWords"
                    android:paddingStart="12dp"
                    android:textColor="#335055"
                    android:textColorHint="#7A8D92" />

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:background="@drawable/bg_circular_editar"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="3dp"
                    android:src="@drawable/editar_simbolo" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalvarStartup"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Salvar"
                android:textAllCaps="false"
                android:textColor="#294B50"
                android:textSize="18sp"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="16dp"
                app:strokeColor="#6BC2C8"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bottom_nav_background"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:weightSum="6">

        <FrameLayout
            android:id="@+id/navHomeContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Home"
            android:focusable="true">

            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/home_simbolo"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navContaContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Conta"
            android:focusable="true">

            <ImageView
                android:id="@+id/navContaIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/minhaconta_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navChatContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Chat"
            android:focusable="true">

            <ImageView
                android:id="@+id/navChatIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/chat_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navFavoritosContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Favoritos"
            android:focusable="true">

            <ImageView
                android:id="@+id/navFavoritosIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/favoritos_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navNotificacoesContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Notificacoes"
            android:focusable="true">

            <ImageView
                android:id="@+id/navNotificacoesIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/notificacao_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navSairContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Sair"
            android:focusable="true">

            <ImageView
                android:id="@+id/navSairIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/logoout_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

    </LinearLayout>

</LinearLayout>