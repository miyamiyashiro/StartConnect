<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_roxo_shape"
    android:orientation="vertical"
    android:padding="30dp">

    <TextView
        android:id="@+id/txtDesfavoritarMsg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="Tem certeza que deseja desfavoritar\n${Startup}?"
        android:textColor="#FFFFFF"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmarDesfavoritar"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="Sim"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:backgroundTint="#45A09E"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelarDesfavoritar"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:text="Voltar"
            android:textAllCaps="false"
            android:textColor="#294B50"
            android:textSize="16sp"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="16dp"
            app:strokeColor="#6BC2C8"
            app:strokeWidth="1dp" />
    </LinearLayout>
</LinearLayout>
