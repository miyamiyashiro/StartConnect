<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/perfilRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header verde/teal com foto e "Perfil @tipo" -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/card_verde"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgPerfil"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/foto_grupo"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_circular_editar"
                android:contentDescription="@null"
                android:padding="3dp"
                android:src="@drawable/editar_simbolo" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textColor="#FFFFFF"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/txtPerfilTipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\@investidor"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Card roxo com campos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        android:layout_weight="1"
        android:background="@drawable/card_roxo_shape"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="26dp">

        <!-- Campo nome -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_border_branco"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:minHeight="54dp"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/nome_conta" />

            <TextView
                android:id="@+id/txtPerfilNome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="12dp"
                android:text="nome"
                android:textColor="#335055"
                android:textSize="16sp" />

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:background="@drawable/bg_circular_editar"
                android:contentDescription="@null"
                android:padding="3dp"
                android:src="@drawable/editar_simbolo" />
        </LinearLayout>

        <!-- Campo email -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_border_branco"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:minHeight="54dp"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_dialog_email" />

            <TextView
                android:id="@+id/txtPerfilEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="12dp"
                android:text="email"
                android:textColor="#335055"
                android:textSize="16sp" />

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:background="@drawable/bg_circular_editar"
                android:contentDescription="@null"
                android:padding="3dp"
                android:src="@drawable/editar_simbolo" />
        </LinearLayout>

        <!-- Botao mudar senha -->
        <LinearLayout
            android:id="@+id/btnMudarSenha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_border_branco"
            android:clickable="true"
            android:elevation="4dp"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="54dp"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_lock_idle_lock" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="12dp"
                android:text="mudar senha"
                android:textColor="#335055"
                android:textSize="16sp" />

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:background="@drawable/bg_circular_editar"
                android:contentDescription="@null"
                android:padding="3dp"
                android:src="@drawable/editar_simbolo" />
        </LinearLayout>

        <!-- Botao apagar conta -->
        <LinearLayout
            android:id="@+id/btnApagarConta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="26dp"
            android:background="@drawable/edittext_border_branco"
            android:clickable="true"
            android:elevation="4dp"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="54dp"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_menu_close_clear_cancel" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="12dp"
                android:text="apagar conta"
                android:textColor="#335055"
                android:textSize="16sp" />

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:background="@drawable/bg_circular_editar"
                android:contentDescription="@null"
                android:padding="3dp"
                android:src="@drawable/editar_simbolo" />
        </LinearLayout>

        <!-- Botao Salvar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalvarPerfil"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Salvar"
            android:textAllCaps="false"
            android:textColor="#294B50"
            android:textSize="18sp"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="16dp"
            app:strokeColor="#6BC2C8"
            app:strokeWidth="1dp" />

    </LinearLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bottom_nav_background"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:weightSum="6">

        <FrameLayout
            android:id="@+id/navHomeContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Home"
            android:focusable="true">
            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/home_simbolo"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navContaContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Conta"
            android:focusable="true">
            <ImageView
                android:id="@+id/navContaIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/minhaconta_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navChatContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Chat"
            android:focusable="true">
            <ImageView
                android:id="@+id/navChatIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/chat_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navFavoritosContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Favoritos"
            android:focusable="true">
            <ImageView
                android:id="@+id/navFavoritosIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/favoritos_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navNotificacoesContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Notificacoes"
            android:focusable="true">
            <ImageView
                android:id="@+id/navNotificacoesIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/notificacao_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/navSairContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="Sair"
            android:focusable="true">
            <ImageView
                android:id="@+id/navSairIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/logoout_menu"
                app:tint="@color/bottom_nav_icon_tint" />
        </FrameLayout>

    </LinearLayout>

</LinearLayout>
